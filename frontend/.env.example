# =============================================================================
#  RingSolutions — Frontend Environment Variables  (Vite / React)
#  Copy this file to .env.local and fill in every value marked  ← FILL THIS
#  Never commit .env.local to git.
#  All variables MUST start with VITE_ to be accessible in the browser.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# API URL
# The full base URL of the backend API — no trailing slash.
# • Local dev:    http://localhost:5000   (Vite proxy handles /api → Flask)
# • Production:   https://api.ringsolutions.com
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://api.ringsolutions.com   # ← FILL THIS  your backend domain


# ─────────────────────────────────────────────────────────────────────────────
# APP INFO  (shown in page title, emails, footer)
# ─────────────────────────────────────────────────────────────────────────────
VITE_APP_NAME=RingSolutions
VITE_SUPPORT_EMAIL=support@ringsolutions.com       # ← FILL THIS


# ─────────────────────────────────────────────────────────────────────────────
# SENTRY  (frontend error monitoring — optional)
# 1. Register at https://sentry.io  →  Create project  →  React
# 2. Copy the DSN from the project settings
# ─────────────────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                                   # ← FILL THIS (optional)
