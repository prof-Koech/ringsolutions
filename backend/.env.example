# =============================================================================
#  RingSolutions — Backend Environment Variables
#  Copy this file to .env and fill in every value marked  ← FILL THIS
#  Never commit .env to git.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# FLASK / SECURITY
# Generate both keys with:  python3 -c "import secrets; print(secrets.token_hex(48))"
# ─────────────────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=                          # ← FILL THIS  (long random hex string)
JWT_SECRET_KEY=                      # ← FILL THIS  (different long random hex string)


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE  (PostgreSQL in production)
# Format:  postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# • Railway:   copy the "DATABASE_URL" from the Railway dashboard
# • Render:    copy "External Database URL" from the Render PostgreSQL service
# • Supabase:  Settings → Database → Connection string (URI)
# For local dev only — swap to:  sqlite:////absolute/path/to/ringsolutions_dev.db
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=                        # ← FILL THIS  e.g. postgresql://user:pass@host:5432/ringsolutions


# ─────────────────────────────────────────────────────────────────────────────
# REDIS & CELERY
# • Railway Redis:  copy the "REDIS_URL" from the Redis service
# • Upstash:        copy "REDIS_URL" (rediss://... with TLS)
# In production CELERY_TASK_ALWAYS_EAGER must be false so tasks queue properly
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=                           # ← FILL THIS  e.g. redis://default:password@host:6379
CELERY_BROKER_URL=                   # ← FILL THIS  same as REDIS_URL
CELERY_RESULT_BACKEND=               # ← FILL THIS  same as REDIS_URL  (or redis://host:6379/1)
CELERY_TASK_ALWAYS_EAGER=false       # keep false in production


# ─────────────────────────────────────────────────────────────────────────────
# EMAIL  (SMTP)
# Option A — Gmail:
#   MAIL_SERVER=smtp.gmail.com | MAIL_PORT=587 | MAIL_USE_TLS=true
#   MAIL_USERNAME=your.email@gmail.com
#   MAIL_PASSWORD= App Password from Google Account → Security → App passwords
#
# Option B — SendGrid (recommended for production):
#   MAIL_SERVER=smtp.sendgrid.net | MAIL_PORT=587 | MAIL_USE_TLS=true
#   MAIL_USERNAME=apikey
#   MAIL_PASSWORD= SendGrid API key from sendgrid.com → Settings → API Keys
#
# Option C — Zoho Mail (free for custom domain):
#   MAIL_SERVER=smtp.zoho.com | MAIL_PORT=587 | MAIL_USE_TLS=true
#   MAIL_USERNAME=noreply@ringsolutions.com
#   MAIL_PASSWORD= Zoho account password or App-specific password
# ─────────────────────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=                       # ← FILL THIS  your sending email address
MAIL_PASSWORD=                       # ← FILL THIS  app password or SMTP password
MAIL_DEFAULT_SENDER=RingSolutions <noreply@ringsolutions.com>


# ─────────────────────────────────────────────────────────────────────────────
# AFRICA'S TALKING  (Bulk SMS)
# 1. Create account at https://africastalking.com
# 2. Go to Settings → API Key  →  copy the API key
# 3. For sandbox testing: AT_USERNAME=sandbox, any key works
# 4. For production: AT_USERNAME = your registered username (not "sandbox")
# 5. AT_SHORTCODE: your assigned shortcode e.g. 20880
# 6. AT_SENDER_ID: your approved sender name e.g. MYSHOP (max 11 chars)
# ─────────────────────────────────────────────────────────────────────────────
AT_USERNAME=                         # ← FILL THIS  e.g. ringsolutions  (use "sandbox" for testing)
AT_API_KEY=                          # ← FILL THIS  from AT dashboard → Settings → API Key
AT_SHORTCODE=                        # ← FILL THIS  your shortcode e.g. 20880
AT_SENDER_ID=RingSol                 # ← FILL THIS  your approved sender name (max 11 chars)


# ─────────────────────────────────────────────────────────────────────────────
# M-PESA DARAJA  (Lipa Na M-Pesa STK Push)
# 1. Register at https://developer.safaricom.co.ke
# 2. Create an app → go to the app details
# 3. MPESA_CONSUMER_KEY + MPESA_CONSUMER_SECRET: from the app credentials tab
# 4. MPESA_SHORTCODE: your Paybill/Till number (sandbox default is 174379)
# 5. MPESA_PASSKEY: from Daraja portal → Lipa Na M-Pesa Online → Passkey
# 6. MPESA_CALLBACK_URL: must be a public HTTPS URL — Safaricom POSTs payment results here
#    Format: https://api.ringsolutions.com/api/webhooks/mpesa/callback
# 7. MPESA_ENVIRONMENT: "sandbox" for testing, "production" for live
# ─────────────────────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=                  # ← FILL THIS  from Daraja app credentials
MPESA_CONSUMER_SECRET=               # ← FILL THIS  from Daraja app credentials
MPESA_SHORTCODE=174379               # ← FILL THIS  your Paybill number (174379 = sandbox default)
MPESA_PASSKEY=                       # ← FILL THIS  from Daraja → Lipa Na M-Pesa → Passkey
MPESA_CALLBACK_URL=https://api.ringsolutions.com/api/webhooks/mpesa/callback  # ← FILL THIS  your live domain
MPESA_ENVIRONMENT=sandbox            # ← change to "production" when going live


# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP BUSINESS CLOUD API  (Meta Graph API)
# 1. Go to https://developers.facebook.com → My Apps → Create App → Business
# 2. Add "WhatsApp" product to the app
# 3. WHATSAPP_PHONE_NUMBER_ID:  WhatsApp → Getting Started → Phone number ID
# 4. WHATSAPP_BUSINESS_ACCOUNT_ID:  WhatsApp → Getting Started → WhatsApp Business Account ID
# 5. WHATSAPP_ACCESS_TOKEN:
#    - Temporary (testing): copy the token from Getting Started (expires in 24h)
#    - Permanent (production): System Users → generate permanent token with
#      whatsapp_business_messaging + whatsapp_business_management permissions
# 6. WHATSAPP_VERIFY_TOKEN: any string YOU choose — used to verify the webhook URL
# 7. Register webhook in Meta dashboard:
#    URL: https://api.ringsolutions.com/api/webhooks/whatsapp
#    Verify Token: same as WHATSAPP_VERIFY_TOKEN below
#    Subscribe to: messages, message_status_updates
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=               # ← FILL THIS  permanent system user token
WHATSAPP_PHONE_NUMBER_ID=            # ← FILL THIS  15-digit number e.g. 123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=        # ← FILL THIS  from Meta Business Manager
WHATSAPP_VERIFY_TOKEN=               # ← FILL THIS  any secret string you choose e.g. ringsol-wh-2025
WHATSAPP_API_VERSION=v20.0


# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY  (Campaign image/poster storage — required for WhatsApp images)
# 1. Register free account at https://cloudinary.com
# 2. Dashboard → API Keys → copy Cloud name, API Key, API Secret
# 3. Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Without this, uploaded images are stored on local disk (not suitable for production)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_URL=                      # ← FILL THIS  e.g. cloudinary://123456789:abcXYZ@mycloudname


# ─────────────────────────────────────────────────────────────────────────────
# FILE UPLOADS  (local fallback when Cloudinary is not set)
# Leave blank to use the default: <project_root>/uploads/
# ─────────────────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=                       # optional — absolute path e.g. /var/www/ringsolutions/uploads


# ─────────────────────────────────────────────────────────────────────────────
# APP URLs
# APP_BASE_URL: the public URL of THIS backend API (used to build image URLs)
# FRONTEND_URL: the public URL of the React frontend (used in email links & CORS)
# ─────────────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://api.ringsolutions.com   # ← FILL THIS  your backend domain
FRONTEND_URL=https://ringsolutions.com       # ← FILL THIS  your frontend domain
APP_NAME=RingSolutions
SUPPORT_EMAIL=support@ringsolutions.com      # ← FILL THIS  your support email


# ─────────────────────────────────────────────────────────────────────────────
# PRICING  (KES — adjust to your margins)
# ─────────────────────────────────────────────────────────────────────────────
SMS_PRICE_PER_MESSAGE=0.80           # what you charge clients per SMS
WHATSAPP_PRICE_PER_MESSAGE=1.20      # what you charge clients per WhatsApp message
CUSTOM_SENDER_ID_FEE=500.00          # monthly fee for a custom sender ID
MINIMUM_TOPUP=100.00                 # minimum M-Pesa top-up amount


# ─────────────────────────────────────────────────────────────────────────────
# SENTRY  (error monitoring — optional but recommended for production)
# 1. Register at https://sentry.io  →  Create project  →  Flask
# 2. Copy the DSN from the project settings
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=                          # ← FILL THIS  e.g. https://abc123@o123.ingest.sentry.io/456
